# Azure AD Configuration
# Get these values from Azure Portal → App Registrations → Your App
REACT_APP_AZURE_CLIENT_ID=your-client-id-here
REACT_APP_AZURE_TENANT_ID=your-tenant-id-here
REACT_APP_AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here

# Backend API Configuration
REACT_APP_API_BASE_URL=https://your-backend-api-url.azurewebsites.net/api

# Authentication Scopes (comma-separated)
REACT_APP_AUTH_SCOPES=openid,profile,User.Read,email

# Cache Configuration
REACT_APP_CACHE_LOCATION=localStorage
REACT_APP_STORE_AUTH_STATE_IN_COOKIE=true
